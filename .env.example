# OpenGradient ALPHA OG Agent - Environment Template
# Copy to .env and fill in values. Use local wallet by default via opengradient config.

# --- OpenGradient Testnet (актуальная сеть) ---
OPENGRADIENT_RPC_URL=https://ogevmdevnet.opengradient.ai
OPENGRADIENT_CHAIN_ID=10740

# --- OpenGradient (x402 LLM) ---
# Private key for Base Sepolia wallet with $OPG testnet tokens.
# Leave unset to use opengradient config (opengradient config init).
# OPENGRADIENT_PRIVATE_KEY=0x...

# --- MemSync (long-term memory) ---
# Get key from https://app.memsync.ai/dashboard/api-keys
MEMSYNC_API_KEY=your_memsync_api_key

# --- Agent identity (for MemSync thread/agent) ---
AGENT_ID=og-chronos-agent
DEFAULT_THREAD_ID=main
