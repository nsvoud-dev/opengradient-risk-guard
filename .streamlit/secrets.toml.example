# Verifiable DeFi Risk Guard — Streamlit Secrets template
#
# LOCAL DEVELOPMENT
#   Copy to .streamlit/secrets.toml and fill in your values.
#   This file is git-ignored; secrets.toml.example is what gets committed.
#
# STREAMLIT CLOUD
#   Do NOT commit secrets.toml.
#   Instead, paste the contents (without comments) into:
#   App dashboard → Settings → Secrets
#
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenGradient wallet ───────────────────────────────────────────────────────
# Private key for the wallet used to submit on-chain inference transactions.
# Must have native OG gas on the devnet (chain 10740).
OPENGRADIENT_PRIVATE_KEY = "0xYOUR_PRIVATE_KEY_HERE"

# ── OpenGradient network ──────────────────────────────────────────────────────
OPENGRADIENT_RPC_URL    = "https://ogevmdevnet.opengradient.ai"
OPENGRADIENT_CHAIN_ID   = "10740"

# ── MemSync (long-term memory / analytics) ───────────────────────────────────
# Get your key at https://app.memsync.ai/dashboard/api-keys
# Leave empty ("") to disable MemSync — the app works without it.
MEMSYNC_API_KEY = ""

# ── Agent identity (used as MemSync thread namespace) ────────────────────────
AGENT_ID         = "og-chronos-agent"
DEFAULT_THREAD_ID = "main"
